{
  "name": "poc-logger",
  "version": "0.2.0",
  "description": "Observability unificata per AWS Lambda — Logger, Tracer, Metrics con output OTel",
  "main": "packages/typescript/dist/cjs/index.js",
  "module": "packages/typescript/dist/esm/index.js",
  "types": "packages/typescript/dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./packages/typescript/dist/esm/index.d.ts",
        "default": "./packages/typescript/dist/esm/index.js"
      },
      "require": {
        "types": "./packages/typescript/dist/cjs/index.d.ts",
        "default": "./packages/typescript/dist/cjs/index.js"
      }
    }
  },
  "scripts": {
    "build": "cd packages/typescript && npm install && npm run build",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.31.0",
    "@aws-lambda-powertools/tracer": "^2.31.0",
    "@aws-lambda-powertools/metrics": "^2.31.0",
    "@middy/core": "^5.0.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0",
    "dotenv": "^16.4.0",
    "@types/aws-lambda": "^8.10.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
